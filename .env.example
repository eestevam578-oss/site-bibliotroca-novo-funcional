# Backend URL para produção
# Por padrão, usa localhost:3000 em desenvolvimento
BACKEND_URL=http://localhost:3000

# Nodemailer - Gmail
# Configure com seu e-mail Gmail e senha de app
# Instruções: https://support.google.com/accounts/answer/185833
GMAIL_EMAIL=seu-email@gmail.com
GMAIL_APP_PASSWORD=sua-senha-app

# Porta do servidor
PORT=3000

# CORS
CORS_ORIGIN=http://localhost:3000
