# ==========================================
# CONFIGURAÇÃO DO SUPABASE
# ==========================================
# Copie este arquivo para .env e preencha com suas credenciais

# URL do seu projeto Supabase
SUPABASE_URL=https://seu-projeto.supabase.co

# Chave pública (anon key) do Supabase
SUPABASE_ANON_KEY=sua-chave-anonima-aqui

# Tipo de backend a usar
# Opções: 'supabase', 'localhost', 'hybrid'
BACKEND_TYPE=supabase

# URL do backend local (se usar 'localhost' ou 'hybrid')
LOCAL_BACKEND_URL=http://localhost:3000

# ==========================================
# CONFIGURAÇÃO DO NODE MAILER (Opcional)
# ==========================================
GMAIL_EMAIL=seu-email@gmail.com
GMAIL_APP_PASSWORD=sua-senha-app

# ==========================================
# CONFIGURAÇÃO DO SERVIDOR
# ==========================================
PORT=3000
CORS_ORIGIN=*
NODE_ENV=development
